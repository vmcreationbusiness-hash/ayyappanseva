{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/server.js"
    },
    {
      "src": "/styles.css",
      "dest": "/styles.css"
    },
    {
      "src": "/app.js",
      "dest": "/app.js"
    },
    {
      "src": "/translations.js",
      "dest": "/translations.js"
    },
    {
      "src": "/ayyappa-bg.png",
      "dest": "/ayyappa-bg.png"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
